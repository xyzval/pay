# ===================================
# QRIS Payment Gateway - Configuration
# ===================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- TELEGRAM BOT -----
# Token dari @BotFather di Telegram
BOT_TOKEN=1234567890:ABCDefghIJKLmnopQRSTuvwxYZ

# ID Telegram admin (bisa lebih dari satu, pisahkan dengan koma)
# Untuk mendapatkan ID, chat @userinfobot di Telegram
ADMIN_IDS=123456789,987654321

# ----- QRIS MITRA BUKALAPAK -----
# Data QRIS statis dari Mitra Bukalapak
# Cara mendapatkan:
# 1. Buka aplikasi Mitra Bukalapak
# 2. Masuk ke menu QRIS / Terima Pembayaran
# 3. Screenshot QR Code
# 4. Scan/decode QR tersebut menggunakan QR scanner (bisa pakai web: webqr.com)
# 5. Copy string data QRIS (dimulai dengan "0002010101...")
QRIS_STATIC=00020101021126570011ID.DANA.WWW01189360091400000000010215000000000000000303UMI51440014ID.CO.QRIS.WWW0215ID10210000000000303UMI5204541153033605802ID5909NAMATOKO6007JAKARTA61051012062070703A0163049A25

# ----- PAYMENT SETTINGS -----
# Waktu expired pembayaran dalam menit (default: 30)
EXPIRY_MINUTES=30

# Interval pengecekan mutasi dalam detik (default: 15)
CHECK_INTERVAL=15

# ----- API SERVER -----
# Port untuk REST API Payment Gateway (default: 8000)
API_PORT=8000

# ----- OPTIONAL: MUTASI API -----
# Jika menggunakan layanan cek mutasi otomatis (Mutasiku, dll)
# Uncomment dan isi sesuai provider:

# MUTASIKU_API_KEY=your_api_key_here
# MUTASIKU_ACCOUNT_ID=your_account_id_here
